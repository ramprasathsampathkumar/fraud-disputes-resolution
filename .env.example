# ── Provider selection ──────────────────────────────────────────────────────
# Switch the entire stack by changing LLM_PROVIDER + the model names below.
# Supported: anthropic | openai
LLM_PROVIDER=anthropic

# ── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── OpenAI (only needed if LLM_PROVIDER=openai) ──────────────────────────────
# OPENAI_API_KEY=sk-...

# ── Model selection ──────────────────────────────────────────────────────────
# Anthropic options : claude-sonnet-4-6 | claude-haiku-4-5-20251001
# OpenAI options    : gpt-4o | gpt-4o-mini
INVESTIGATOR_MODEL=claude-haiku-4-5-20251001
CLASSIFIER_MODEL=claude-haiku-4-5-20251001

# ── LangSmith (free tier: smith.langchain.com) ───────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_lsv2_pt_key_here
LANGCHAIN_PROJECT=fraud-disputes-resolution
